# Auto detect text files and perform LF normalization
* text=auto

# JavaScript files - use LF line endings
*.js text eol=lf
*.jsx text eol=lf

# TypeScript files - use LF line endings
*.ts text eol=lf
*.tsx text eol=lf

# JSON files - use LF line endings  
*.json text eol=lf

# Markdown files - use LF line endings
*.md text eol=lf

# CSS files - use LF line endings
*.css text eol=lf

# HTML files - use LF line endings
*.html text eol=lf

# Configuration files - use LF line endings
*.config text eol=lf
*.env text eol=lf

# Shell scripts - use LF line endings
*.sh text eol=lf

# Batch files - use CRLF line endings (Windows specific)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files - treat as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.mp3 binary
*.pdf binary
*.zip binary
